COMPOSE_PROJECT_NAME=sentinelai

DJANGO_SETTINGS_MODULE=config.settings.production
DJANGO_SECRET_KEY=replace-with-a-long-random-production-secret
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,sentinelai.local,backend
DJANGO_SECURE_SSL_REDIRECT=False
DJANGO_SESSION_COOKIE_SECURE=False
DJANGO_CSRF_COOKIE_SECURE=False
DJANGO_SECURE_HSTS_SECONDS=0

CORS_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost,http://127.0.0.1
FRONTEND_PASSWORD_RESET_URL=http://localhost/reset-password

MONGO_INITDB_ROOT_USERNAME=sentinelai_admin
MONGO_INITDB_ROOT_PASSWORD=change-me-immediately
MONGODB_NAME=sentinelai
MONGODB_CONNECT_TIMEOUT_MS=5000
MONGODB_SERVER_SELECTION_TIMEOUT_MS=5000

CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
CELERY_WORKER_CONCURRENCY=2

LOG_LEVEL=INFO
GUNICORN_WORKERS=3
GUNICORN_TIMEOUT=120
VITE_API_BASE_URL=/api/v1
